{
  "productName": "target"  "version": "0.1.0",
  "identifier": "com.target.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "../frontend",
    "distDir": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Target",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "identifier": "com.target.app",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": [],
    "targets": "all"
  }
}
